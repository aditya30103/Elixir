# OpenRouter API key for CrewAI agents
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use via OpenRouter (any free model works)
# See https://openrouter.ai/models?q=free for options
OPENROUTER_MODEL=openrouter/qwen/qwen3-235b-a22b:free

# URL of the deployed frontend (for CORS) — set this on Railway
# e.g. https://elixir-frontend-sand.vercel.app
FRONTEND_URL=http://localhost:3000
