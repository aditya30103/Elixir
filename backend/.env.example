# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model for lightweight/fast tasks (routing, summarization)
# Default: qwen free tier. Swap for a paid model when needed.
OPENROUTER_MODEL_FLASH=openrouter/openai/gpt-oss-20b:free

# Model for heavy reasoning tasks (character agents, analysis, RAG)
# Default: GPT OSS 120B free tier. Swap for a stronger model when needed.
OPENROUTER_MODEL_PRO=openrouter/openai/gpt-oss-120b:free

# URL of the deployed frontend (for CORS) — set as a Secret on Hugging Face Spaces
# e.g. https://elixir.vercel.app
FRONTEND_URL=http://localhost:3000
